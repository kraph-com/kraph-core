# Supaba Node Configuration for Confidential VM
# These values are baked into the initrd and become part of the measurement.
# Runtime-specific values (RPC URL, keypair) should be injected via
# the KBS key release mechanism or virtio-vsock from the host.

SUPABA_HOSTNAME=0.0.0.0
SUPABA_API_PORT=3401
SUPABA_PORT_RANGE_START=10000
SUPABA_PORT_RANGE_END=60000
SUPABA_MAX_INSTANCES=10
SUPABA_WARM_POOL_SIZE=1
SUPABA_HEARTBEAT_INTERVAL_MS=300000
SUPABA_CLEANUP_INTERVAL_MS=60000
SUPABA_WAL_ARCHIVE_INTERVAL_MS=30000
SUPABA_DOCKER_SOCKET=/var/run/docker.sock
SUPABA_REGION=unknown
SUPABA_REQUIRE_ATTESTATION=true
